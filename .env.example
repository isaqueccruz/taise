# ============================================================================
# Arquivo de Exemplo: Copie este arquivo para .env e preencha os valores
# ============================================================================

# URL de conexão com o Supabase
# Obtenha em: Supabase → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:password@db.supabaseproject.com:5432/postgres

# Ambiente (development ou production)
NODE_ENV=development

# Porta do servidor local
PORT=3000

# Chave secreta para sessões (gere uma string aleatória)
SESSION_SECRET=sua_chave_secreta_super_segura_aqui_12345

# Email para receber notificações de contato
ADMIN_EMAIL=admin@confeitaria.com

# Número do WhatsApp (sem espaços ou caracteres especiais)
WHATSAPP_NUMBER=5571988461789
