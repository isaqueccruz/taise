{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/trpc/(.*)",
      "destination": "/server/_core/index.ts"
    },
    {
      "source": "/admin(.*)",
      "destination": "/server/_core/index.ts"
    },
    {
      "source": "/((?!api/trpc|admin).*)",
      "destination": "/$1"
    }
  ]
}